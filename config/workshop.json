{
  "workshopTitle": "Construction Robotics PRD Workshop",
  "purpose": "A one-hour stakeholder exercise to define preliminary requirements for a fictional construction robot.",
  "disclaimer": "This workshop is designed to generate stakeholder intelligence that may inform a Product Requirements Document. It is not intended to produce a complete, validated, or approved PRD in one hour.",

  "robot": {
    "_note": "PLACEHOLDER — the facilitator will define the fictional robot and provide images later. Replace every value below and drop image files into assets/robot/. Nothing else in the app needs to change.",
    "name": "[ROBOT NAME — TBD]",
    "tagline": "[One-line description of what the robot does — TBD]",
    "images": [
      "/assets/robot/robot-placeholder.svg"
    ],
    "task": "[The construction activity the robot performs — TBD]",
    "environment": "[The preliminary operating environment — TBD]",
    "autonomyLevel": "[Expected level of autonomy — TBD]",
    "consumables": "[Materials, tools, or consumables it requires — TBD]",
    "assumptions": [
      "[Fixed operating assumption #1 — TBD]",
      "[Fixed operating assumption #2 — TBD]",
      "[Fixed operating assumption #3 — TBD]"
    ],
    "constraints": [
      "[Known constraint #1 — TBD]",
      "[Known constraint #2 — TBD]"
    ],
    "unresolvedQuestions": [
      "[Intentionally unresolved question #1 — TBD]",
      "[Intentionally unresolved question #2 — TBD]",
      "[Intentionally unresolved question #3 — TBD]"
    ]
  },

  "groupNamePool": ["Atlas", "Crane", "Rover", "Dozer", "Survey", "Lift", "Girder", "Anchor"],

  "defaults": {
    "targetGroupSize": 4,
    "minGroupSize": 3,
    "maxGroupSize": 5,
    "minGroups": 4,
    "maxGroups": 6,
    "votesPerParticipant": 2,
    "silentThinkingSeconds": 45,
    "defaultSectionTimerSeconds": 660
  },

  "sections": [
    {
      "key": "users_capabilities",
      "title": "Users and Capabilities",
      "order": 1,
      "objective": "Define what the robot must accomplish, who will use it, and the conditions under which it must operate.",
      "mainPrompt": "What must this robot accomplish, for whom, and under what jobsite conditions?",
      "image": "/assets/robot/section-1.svg",
      "defaultTimerSeconds": 660,
      "fields": [
        { "key": "primary_user", "label": "Primary user" },
        { "key": "primary_problem", "label": "Primary problem being solved" },
        { "key": "required_capabilities", "label": "Required robot capabilities" },
        { "key": "method", "label": "Expected method of performing the work" },
        { "key": "operator_skill", "label": "Operator skill level" },
        { "key": "required_training", "label": "Required training" },
        { "key": "environmental_conditions", "label": "Environmental conditions" },
        { "key": "jobsite_constraints", "label": "Jobsite constraints" },
        { "key": "most_important", "label": "Most important requirement" }
      ]
    },
    {
      "key": "workflow_deployment",
      "title": "Workflow and Deployment",
      "order": 2,
      "objective": "Define how the robot enters, operates within, and exits the construction workflow.",
      "mainPrompt": "What must happen before, during, and after the robot performs its work?",
      "image": "/assets/robot/section-2.svg",
      "defaultTimerSeconds": 780,
      "fields": [
        { "key": "mobilization", "label": "Mobilization and setup" },
        { "key": "software_setup", "label": "Software setup" },
        { "key": "mission_planning", "label": "Mission planning" },
        { "key": "connectivity", "label": "Connectivity" },
        { "key": "poor_connectivity", "label": "Poor-connectivity behavior" },
        { "key": "teleoperation", "label": "Teleoperation and intervention" },
        { "key": "telematics", "label": "Telematics and reporting" },
        { "key": "replenishment", "label": "Material or consumable replenishment" },
        { "key": "worker_interaction", "label": "Worker interaction" },
        { "key": "shutdown", "label": "Shutdown and demobilization" },
        { "key": "recovery", "label": "Recovery after interruption" },
        { "key": "preceding_work", "label": "Preceding work dependencies" },
        { "key": "downstream", "label": "Downstream implications" },
        { "key": "most_important", "label": "Most important workflow requirement" }
      ]
    },
    {
      "key": "safety_failure",
      "title": "Safety, Failure, and Human Interaction",
      "order": 3,
      "objective": "Define how the system prevents harm, behaves during failure, interacts with people and equipment, and fits within company procedures.",
      "mainPrompt": "How should the system prevent harm, stop safely, and recover when assumptions fail?",
      "image": "/assets/robot/section-3.svg",
      "defaultTimerSeconds": 780,
      "fields": [
        { "key": "human_interactions", "label": "Expected human interactions" },
        { "key": "hazards", "label": "Foreseeable hazards" },
        { "key": "engineering_controls", "label": "Engineering controls" },
        { "key": "administrative_controls", "label": "Administrative controls" },
        { "key": "sop_integration", "label": "Required SOP integration" },
        { "key": "right_of_way", "label": "Right-of-way rules" },
        { "key": "safe_stop", "label": "Safe-stop behavior" },
        { "key": "emergency_stop", "label": "Emergency stop behavior" },
        { "key": "loss_of_connectivity", "label": "Loss-of-connectivity response" },
        { "key": "recovery_process", "label": "Recovery process" },
        { "key": "successful_failure", "label": "Successful failure" },
        { "key": "most_important", "label": "Most important safety requirement" }
      ]
    }
  ],

  "roleCategories": [
    "General contractor",
    "Specialty contractor",
    "Startup founder",
    "Robotics or product team",
    "Venture capital or investor",
    "Architect or engineer",
    "Owner or developer",
    "Technology provider",
    "Other"
  ]
}
